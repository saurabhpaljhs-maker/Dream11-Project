pipeline {
    agent any

    environment {
        APP_NAME        = "devops-mega-app"
        IMAGE_TAG       = "${env.BUILD_NUMBER}"
        DOCKERHUB_REPO  = credentials('dockerhub-repo')
        GITOPS_REPO     = credentials('gitops-repo-url')
        ARGOCD_SERVER   = credentials('argocd-server-url')
        DOCKERHUB_CREDS = credentials('dockerhub-creds')
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install & Unit Test') {
            steps {
                dir('app') {
                    sh 'npm ci'
                    sh 'npm test'
                }
            }
        }

        stage('Sonar Scan') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh 'sonar-scanner -Dproject.settings=security/sonar-project.properties'
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                dir('app') {
                    dependencyCheck additionalArguments: '--suppression ../security/owasp-suppressions.xml --scan .',
                                     odcInstallation: 'OWASP-DC'
                    dependencyCheckPublisher pattern: 'dependency-check-report.xml'
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                sh 'trivy fs --config security/trivy.yaml app/'
            }
        }

        stage('Docker Build') {
            steps {
                dir('app') {
                    sh 'docker build -t $DOCKERHUB_REPO:$IMAGE_TAG .'
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh 'trivy image --config security/trivy.yaml $DOCKERHUB_REPO:$IMAGE_TAG'
            }
        }

        stage('Docker Push') {
            steps {
                sh 'echo "$DOCKERHUB_CREDS_PSW" | docker login -u "$DOCKERHUB_CREDS_USR" --password-stdin'
                sh 'docker push $DOCKERHUB_REPO:$IMAGE_TAG'
            }
        }

        stage('Update GitOps Repo') {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'gitops-ssh-key', keyFileVariable: 'SSH_KEY')]) {
                    sh '''
                        export GIT_SSH_COMMAND="ssh -i $SSH_KEY -o StrictHostKeyChecking=no"
                        rm -rf gitops-repo
                        git clone "$GITOPS_REPO" gitops-repo
                        cd gitops-repo
                        sed -i "s|image: .*|image: ${DOCKERHUB_REPO}:${IMAGE_TAG}|g" k8s/deployment.yaml
                        git config user.email "jenkins-ci@local"
                        git config user.name "jenkins-ci"
                        git commit -am "deploy ${APP_NAME} build ${IMAGE_TAG}" || echo "nothing to commit"
                        git push origin main
                    '''
                }
            }
        }

        stage('ArgoCD Sync') {
            steps {
                withCredentials([string(credentialsId: 'argocd-auth-token', variable: 'ARGOCD_TOKEN')]) {
                    sh '''
                        argocd app sync "$APP_NAME" --auth-token "$ARGOCD_TOKEN" --server "$ARGOCD_SERVER"
                        argocd app wait "$APP_NAME" --auth-token "$ARGOCD_TOKEN" --server "$ARGOCD_SERVER" --health
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Build ${IMAGE_TAG} deployed successfully via ArgoCD"
        }
        failure {
            echo "Pipeline failed - check which stage broke above"
        }
        always {
            sh 'docker logout || true'
        }
    }
}
