pipeline {
    agent { label 'docker-agent' }

    environment {
        APP_NAME       = "devops-mega-app"
        IMAGE_TAG      = "${env.BUILD_NUMBER}"
        DOCKERHUB_REPO = credentials('dockerhub-repo')
        GITOPS_REPO    = credentials('gitops-repo-url')
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install & Unit Test') {
            steps {
                dir('app') {
                    sh 'npm ci'
                    sh 'npm test'
                }
            }
        }

        stage('Sonar Scan') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh 'sonar-scanner -Dproject.settings=security/sonar-project.properties'
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                sh 'trivy fs --config security/trivy.yaml app/'
            }
        }

        stage('Docker Build') {
            steps {
                dir('app') {
                    sh 'docker build -t $DOCKERHUB_REPO:$IMAGE_TAG .'
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh 'trivy image --config security/trivy.yaml $DOCKERHUB_REPO:$IMAGE_TAG'
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub',
                                                   usernameVariable: 'DOCKER_USER',
                                                   passwordVariable: 'DOCKER_PASS')]) {
                    sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                    sh 'docker push $DOCKERHUB_REPO:$IMAGE_TAG'
                }
            }
        }

        stage('Update GitOps Repo') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-credentials',
                                                   usernameVariable: 'GIT_USER',
                                                   passwordVariable: 'GIT_TOKEN')]) {
                    sh '''
                        rm -rf gitops-repo
                        git clone https://${GIT_USER}:${GIT_TOKEN}@github.com/saurabhpaljhs-maker/Dream11-Project.git gitops-repo
                        cd gitops-repo
                        sed -i "s|image: .*|image: ${DOCKERHUB_REPO}:${IMAGE_TAG}|g" k8s/deployment.yaml
                        git config user.email "jenkins-ci@local"
                        git config user.name "jenkins-ci"
                        git commit -am "deploy ${APP_NAME} build ${IMAGE_TAG}" || echo "nothing to commit"
                        git push https://${GIT_USER}:${GIT_TOKEN}@github.com/saurabhpaljhs-maker/Dream11-Project.git main
                    '''
                }
            }
        }

        // ArgoCD sync - uncomment this once EKS cluster is up and ArgoCD is installed.
        // Needs two more credentials: argocd-server-url, argocd-auth-token
        /*
        stage('ArgoCD Sync') {
            steps {
                withCredentials([string(credentialsId: 'argocd-auth-token', variable: 'ARGOCD_TOKEN'),
                                  string(credentialsId: 'argocd-server-url', variable: 'ARGOCD_SERVER')]) {
                    sh '''
                        argocd app sync "$APP_NAME" --auth-token "$ARGOCD_TOKEN" --server "$ARGOCD_SERVER"
                        argocd app wait "$APP_NAME" --auth-token "$ARGOCD_TOKEN" --server "$ARGOCD_SERVER" --health
                    '''
                }
            }
        }
        */
    }

    post {
        success {
            echo "Build ${IMAGE_TAG} pushed to DockerHub and gitops repo updated"
        }
        failure {
            echo "Pipeline failed - check which stage broke above"
        }
        always {
            sh 'docker logout || true'
        }
    }
}
